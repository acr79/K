# K Configuration
# Copy to .env and fill in your values

# KLLM inference (Windows rig IP when built, localhost for local testing)
KLLM_BASE_URL=http://localhost:8080/v1
KLLM_MODEL=llama3-8b

# Qdrant vector DB (local Docker by default)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=           # fill in when using Qdrant Cloud

# Wake-on-LAN (fill in when rig is built)
# RIG_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
# RIG_IP=192.168.1.100
# RIG_BOOT_WAIT=90

# Voice
VOICE_ENABLED=false
WHISPER_MODEL=base.en

# Storage
# K_HOME=~/.k             # where K stores its database
